---
import InitiativeTracker from '../components/InitiativeTracker';
import Layout from '../layouts/Layout.astro';

// WebSite Schema with SearchAction for SEO
const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "Initiative Tracker",
	"url": Astro.site,
	"description": "Free online initiative tracker for D&D 5e with AI encounter generation, 300+ monsters, and drag-and-drop combat management. Perfect for Dungeon Masters.",
	"potentialAction": {
		"@type": "SearchAction",
		"target": {
			"@type": "EntryPoint",
			"urlTemplate": `${Astro.site}?q={search_term_string}`
		},
		"query-input": "required name=search_term_string"
	}
};

// BreadcrumbList Schema for navigation
const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": Astro.site
		}
	]
};
---

<Layout 
	title="Initiative Tracker - Free D&D 5e Combat Management Tool"
	description="Free online initiative tracker for D&D 5e with AI encounter generation, 300+ monsters, and drag-and-drop combat management. Perfect for Dungeon Masters."
>
	<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	<div class="flex flex-col flex-1 h-full min-h-0 px-4 md:px-8 py-4">
		<InitiativeTracker client:only="react">
			<span slot="fallback">Loading...</span>
		</InitiativeTracker>
	</div>
</Layout>
